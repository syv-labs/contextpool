# ContextPool CLI — environment variables
# None are required for local-only usage.

# Team API key (alternative to `cxp auth <key>` / system keychain)
# CXP_API_KEY=cxp_team_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ContextPool API server URL (default: https://api.contextpool.dev)
# CXP_API_URL=http://localhost:3210

# LLM backend for summarization (checked in this order):
#   1. `claude` CLI in PATH  — used automatically, no key needed
#   2. ANTHROPIC_API_KEY      — Anthropic API
#   3. OPENAI_API_KEY         — OpenAI API
#   4. NVIDIA_API_KEY         — NVIDIA API
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# NVIDIA_API_KEY=nvapi-...
